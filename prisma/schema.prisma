generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Spot {
  id                 String       @id @default(cuid())
  name               String
  description        String?
  latitude           Float
  longitude          Float
  country            String?
  region             String?
  difficulty         Difficulty   @default(INTERMEDIATE)
  waterType          WaterType    @default(CHOP)
  minWindKmh         Int          @default(15)
  maxWindKmh         Int          @default(35)
  bestMonths         String[]
  bestWindDirections String[]
  hazards            String?
  access             String?
  sportType          SportType    @default(KITE)
  nearestStationId   String?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  accessDe           String?
  accessEn           String?
  accessIt           String?
  descriptionDe      String?
  descriptionEn      String?
  descriptionIt      String?
  hazardsDe          String?
  hazardsEn          String?
  hazardsIt          String?
  favorites          Favorite[]
  images             SpotImage[]
  reports            WindReport[]
}

/// Synced from Supabase Auth on first login.
model User {
  id          String          @id
  email       String          @unique
  name        String?
  avatarUrl   String?
  createdAt   DateTime        @default(now())
  favorites   Favorite[]
  posts       ForumPost[]
  topics      ForumTopic[]
  votes       ForumVote[]
  preferences UserPreference?
}

/// Per-user UI preferences (map filters, units, etc.)
model UserPreference {
  id           String   @id @default(cuid())
  userId       String   @unique
  sportFilter  String   @default("ALL")
  useKnots     Boolean  @default(true)
  updatedAt    DateTime @updatedAt
  mapCenterLat Float?
  /// Last map view (persisted across devices when authenticated)
  mapCenterLng Float?
  mapZoom      Float?
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  spotId    String
  createdAt DateTime @default(now())
  spot      Spot     @relation(fields: [spotId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, spotId])
  @@index([userId])
}

model SpotImage {
  id        String   @id @default(cuid())
  spotId    String
  url       String
  caption   String?
  createdAt DateTime @default(now())
  spot      Spot     @relation(fields: [spotId], references: [id], onDelete: Cascade)
}

model WindReport {
  id            String   @id @default(cuid())
  spotId        String
  date          DateTime @default(now())
  windSpeedKmh  Float
  windDirection Int
  gustsKmh      Float?
  isKitable     Boolean  @default(true)
  comment       String?
  rating        Int      @default(3)
  createdAt     DateTime @default(now())
  spot          Spot     @relation(fields: [spotId], references: [id], onDelete: Cascade)
}

/// Stores live station wind measurements every 10 minutes (via cron).
/// Used to build a real-time 48h history chart without relying on the
/// ~2-hour-delayed MeteoSwiss OGD CSV files.
model StationMeasurement {
  id            String   @id @default(cuid())
  stationId     String
  time          DateTime
  windSpeedKmh  Float
  windDirection Float
  gustsKmh      Float?
  temperatureC  Float?
  source        String   @default("meteoswiss")
  createdAt     DateTime @default(now())

  @@unique([stationId, time])
  @@index([stationId, time])
}

/// Key-value store for internal config (e.g. Netatmo rotating refresh token).
model SystemConfig {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model ForumCategory {
  id          String       @id @default(cuid())
  name        String       @unique
  slug        String       @unique
  description String?
  order       Int          @default(0)
  icon        String?
  topics      ForumTopic[]
}

model ForumTopic {
  id         String        @id @default(cuid())
  title      String
  slug       String
  body       String
  pinned     Boolean       @default(false)
  locked     Boolean       @default(false)
  authorId   String
  categoryId String
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  posts      ForumPost[]
  author     User          @relation(fields: [authorId], references: [id], onDelete: Cascade)
  category   ForumCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  votes      ForumVote[]

  @@index([categoryId, createdAt])
  @@index([authorId])
}

model ForumPost {
  id        String      @id @default(cuid())
  body      String
  authorId  String
  topicId   String
  parentId  String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  author    User        @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent    ForumPost?  @relation("PostReplies", fields: [parentId], references: [id], onDelete: Cascade)
  children  ForumPost[] @relation("PostReplies")
  topic     ForumTopic  @relation(fields: [topicId], references: [id], onDelete: Cascade)
  votes     ForumVote[]

  @@index([topicId, createdAt])
  @@index([parentId])
}

model ForumVote {
  id        String      @id @default(cuid())
  value     Int
  userId    String
  topicId   String?
  postId    String?
  createdAt DateTime    @default(now())
  post      ForumPost?  @relation(fields: [postId], references: [id], onDelete: Cascade)
  topic     ForumTopic? @relation(fields: [topicId], references: [id], onDelete: Cascade)
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, topicId])
  @@unique([userId, postId])
  @@index([topicId])
  @@index([postId])
}

enum Difficulty {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  EXPERT
}

enum WaterType {
  FLAT
  CHOP
  WAVES
  MIXED
}

enum SportType {
  KITE
  PARAGLIDE
}
